# Standard Postgres connection string.
# Recommended: Neon free tier for this worker, or another free/self-hosted Postgres.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
DB_CONNECT_TIMEOUT_SECONDS=30
HTTP_TIMEOUT_MS=30000

# Normal WhatsApp group JID. You get this after the Baileys sender account joins
# the group. It usually looks like 120363xxxxxxxxxxxx@g.us.
WHATSAPP_GROUP_JID=120363xxxxxxxxxxxx@g.us
# Keep this on persistent disk for Baileys. On a VPS, /opt/nhs-jobs/auth_info is a good value.
WHATSAPP_AUTH_DIR=auth_info

# Default search behavior. Keep this comma-separated list focused; broad terms
# like "fellow", "senior", or "jcf" are intentionally not used.
SEARCH_KEYWORDS=Clinical Fellow,Junior Clinical Fellow,Clinical Research Fellow,Foundation House officer 1,Foundation House Officer 2,Foundation Year 2,Core Trainee (CT1/2)
# NHS Jobs can return broad first-page matches, so the scraper walks sorted pages.
JOBS_NHS_UK_MAX_PAGES=10
HSCNI_MAX_PAGES=5
NHS_SCOTLAND_MAX_PAGES=8
SCRAPE_INTERVAL_CRON=*/10 * * * *

# Keep sends human-paced.
SEND_MIN_DELAY_MS=8000
SEND_MAX_DELAY_MS=15000

# Use true while testing the scrape/database pipeline without sending WhatsApp messages.
DRY_RUN_SENDS=false
# Defaults to true on Vercel so Baileys does not try to write auth files there. Use false on a VPS.
DISABLE_WHATSAPP_SENDS=false

# Optional: set this in Vercel if you want to protect /api/cron manual runs.
# Then call it with Authorization: Bearer your-secret.
CRON_SECRET=

# Logging.
LOG_LEVEL=info

# Optional source toggles.
ENABLE_HEALTHJOBSUK=true
ENABLE_JOBS_NHS_UK=true
ENABLE_NHS_SCOTLAND=true
ENABLE_NHSJOBS_COM=true
ENABLE_HSCNI=true
