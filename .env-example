# Standard Postgres connection string.
# Recommended: Neon free tier for this worker, or Supabase/free/self-hosted Postgres.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Normal WhatsApp group JID. You get this after the Baileys sender account joins
# the group. It usually looks like 120363xxxxxxxxxxxx@g.us.
WHATSAPP_GROUP_JID=120363xxxxxxxxxxxx@g.us

# Default search behavior.
SEARCH_KEYWORD=junior clinical fellow
SCRAPE_INTERVAL_CRON=*/10 * * * *

# Keep sends human-paced.
SEND_MIN_DELAY_MS=8000
SEND_MAX_DELAY_MS=15000

# Use true while testing the scrape/database pipeline without sending WhatsApp messages.
DRY_RUN_SENDS=true

# Logging.
LOG_LEVEL=info

# Optional source toggles.
ENABLE_HEALTHJOBSUK=true
ENABLE_JOBS_NHS_UK=true
ENABLE_NHS_SCOTLAND=true
ENABLE_NHSJOBS_COM=true
